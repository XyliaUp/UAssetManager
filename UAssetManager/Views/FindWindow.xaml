<Window x:Class="UAssetManager.Views.FindWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        Title="{DynamicResource FindWindow_Title}" MinWidth="400">
    
    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Content -->
        <DockPanel Grid.Row="0" Margin="10">
            <Label Content="{DynamicResource FindWindow_SearchContent}" Margin="0 0 2 0" />
			<TextBox x:Name="SearchForTextBox" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Options -->
            <GroupBox Grid.Column="0" Header="{DynamicResource FindWindow_Options}" Style="{StaticResource GroupBoxStyle}">
                <StackPanel>
                    <CheckBox IsChecked="{Binding CaseSensitive}" Content="{DynamicResource FindWindow_CaseSensitive}" Margin="0 0 0 5" />
                    <CheckBox IsChecked="{Binding UseRegex}" Content="{DynamicResource FindWindow_UseRegex}" />
                </StackPanel>
            </GroupBox>

            <!-- Search Direction -->
            <GroupBox Grid.Column="1" Header="{DynamicResource FindWindow_SearchDirection}" Style="{StaticResource GroupBoxStyle}">
                <StackPanel>
                    <RadioButton Content="{DynamicResource FindWindow_Forward}" VerticalAlignment="Center" IsChecked="{Binding IsForward}" Margin="0 0 0 5" />
                    <RadioButton Content="{DynamicResource FindWindow_Backward}" VerticalAlignment="Center" IsChecked="{Binding IsForward, Converter={StaticResource BooleanNegationConverter}}" />
                </StackPanel>
            </GroupBox>
        </Grid>
        
        <!-- Progress Bar -->
        <StackPanel Grid.Row="2" Margin="10" Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Label Content="{DynamicResource FindWindow_Searching}" />
            <ProgressBar Height="20" Margin="5" IsIndeterminate="True"/>
        </StackPanel>

        <!-- Results Area -->
        <GroupBox Grid.Row="3" Header="{DynamicResource FindWindow_SearchResults}" Style="{StaticResource GroupBoxStyle}"
                  Visibility="{Binding SearchResults.Count,Converter={StaticResource NumberToVisibilityConverter}}">
			<ListBox ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedResult}" >
				<ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Button Area -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
			<Button Command="{Binding PerformSearchCommand}" Content="{DynamicResource FindWindow_FindNext}" IsDefault="True" 
                    Style="{StaticResource ButtonStyle}" Visibility="{Binding IsForward,Converter={StaticResource BooleanToVisibilityReConverter}}" />
			<Button Command="{Binding PerformSearchCommand}" Content="{DynamicResource FindWindow_FindPrev}" IsDefault="True" 
                    Style="{StaticResource ButtonStyle}" Visibility="{Binding IsForward,Converter={StaticResource BooleanToVisibilityConverter}}" />
            
            <Button Command="{Binding FindAllCommand}" Content="{DynamicResource FindWindow_FindAll}" Style="{StaticResource ButtonStyle}" />
            <Button Command="{Binding CancelCommand}" Content="{DynamicResource FindWindow_Cancel}" Style="{StaticResource ButtonStyle}" Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Window>
